data<-read_csv("../data/DCOILWTICO.csv")
getSymbols("DCOILWTICO", src="FRED")
oil <- data.frame(
date = index(DCOILWTICO),
price = as.numeric(DCOILWTICO$DCOILWTICO)
)
oil <- oil %>%
drop_na()
oil <- oil %>%
mutate(
return = c(NA, diff(log(price)))
) %>%
drop_na()
head(oil)
ggplot(oil, aes(date, price)) +
geom_line() +
labs(title="WTI Oil Price")
returns <- oil$return
n <- length(returns)
log_post <- function(mu, sigma){
if(sigma <= 0) return(-Inf)
ll <- sum(dnorm(returns, mu, sigma, log=TRUE))
prior_mu <- dnorm(mu,0,10,log=TRUE)
prior_sigma <- dnorm(sigma,0,5,log=TRUE)
ll + prior_mu + prior_sigma
}
mh_sampler <- function(iter=5000){
mu <- 0
sigma <- 1
samples <- matrix(NA, iter, 2)
for(i in 1:iter){
mu_prop <- rnorm(1, mu, 0.01)
sigma_prop <- abs(rnorm(1, sigma, 0.01))
log_alpha <- log_post(mu_prop,sigma_prop) -
log_post(mu,sigma)
if(log(runif(1)) < log_alpha){
mu <- mu_prop
sigma <- sigma_prop
}
samples[i,] <- c(mu,sigma)
}
samples
}
mh_samples <- mh_sampler(10000)
mcmc_obj <- as.mcmc(mh_samples)
