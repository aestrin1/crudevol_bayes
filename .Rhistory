p <- function(distribution, realization) {
d(distribution)(realization)
}
Bern = function(probability_to_get_one) {
DiscreteDistribution(supp = 0:1,
prob = c(1-probability_to_get_one,
probability_to_get_one))
}
Normal = function(mu = 0, sigma = 1) {
Norm(mu, sigma)
}
simulate <- function(distribution) {
r(distribution)(1)
}
observe = function(realization, distribution) {
weight <<- weight * p(distribution, realization)
}
posterior_particles = function(ppl_function, number_of_iterations) {
weight <<- 1.0
sample = ppl_function()
dimension = length(sample)
samples = matrix(0,
nrow = number_of_iterations,
ncol = dimension,
dimnames = list(1:number_of_iterations,
names(sample)))
weights = rep(0, number_of_iterations)
for (i in 1:number_of_iterations) {
weight <<- 1.0
sample = ppl_function()
samples[i,] = sample
weights[i]  = weight
}
return(list(samples=samples, weights=weights))
}
effective_sample_size = function(w){
(sum(w)^2)/sum(w^2)
}
oil_model = function(){
mu = simulate(Normal(0,10))
sigma = abs(simulate(Normal(0,5)))
for(r in returns){
observe(r, Normal(mu, sigma))
}
c(mu = mu, sigma = sigma)
}
particles <- posterior_particles(oil_model, 5000)
ess_snis <- effective_sample_size(particles$weights)
particles <- posterior_particles(oil_model, 5000)
particles <- posterior_particles(oil_model, 100)
ess_snis <- effective_sample_size(particles$weights)
ess_snis
plot(particles$samples[,1],
particles$samples[,2],
col=rgb(0,0,1,0.2),
xlab="mu",
ylab="sigma",
main="SNIS Posterior Samples")
log_post <- function(theta){
mu <- theta[1]
sigma <- abs(theta[2])
if(sigma <= 0) return(-Inf)
ll <- sum(dnorm(returns, mu, sigma, log=TRUE))
prior_mu <- dnorm(mu,0,10,log=TRUE)
prior_sigma <- dnorm(sigma,0,5,log=TRUE)
ll + prior_mu + prior_sigma
}
mh_sampler <- function(iter=10000){
theta <- c(0,1)
samples <- matrix(NA, iter, 2)
for(i in 1:iter){
proposal <- rnorm(2, theta, c(0.01,0.01))
log_alpha <- log_post(proposal) - log_post(theta)
if(log(runif(1)) < log_alpha){
theta <- proposal
}
samples[i,] <- theta
}
samples
}
mh_samples <- mh_sampler(10000)
mcmc_obj <- as.mcmc(mh_samples)
library(tidyverse)
library(quantmod)
library(readr)
library(rstan)
library(coda)
source("../func/simple_utils.R")
rstan_options(auto_write = TRUE)
options(mc.cores = parallel::detectCores())
log_post <- function(theta){
mu <- theta[1]
sigma <- abs(theta[2])
if(sigma <= 0) return(-Inf)
ll <- sum(dnorm(returns, mu, sigma, log=TRUE))
prior_mu <- dnorm(mu,0,10,log=TRUE)
prior_sigma <- dnorm(sigma,0,5,log=TRUE)
ll + prior_mu + prior_sigma
}
mh_sampler <- function(iter=10000){
theta <- c(0,1)
samples <- matrix(NA, iter, 2)
for(i in 1:iter){
proposal <- rnorm(2, theta, c(0.01,0.01))
log_alpha <- log_post(proposal) - log_post(theta)
if(log(runif(1)) < log_alpha){
theta <- proposal
}
samples[i,] <- theta
}
samples
}
mh_samples <- mh_sampler(10000)
mcmc_obj <- as.mcmc(mh_samples)
plot(mcmc_obj)
summary(mcmc_obj)
stan_model_code <- "
data{
int<lower=0> N;
vector[N] r;
}
parameters{
real mu;
real<lower=0> sigma;
}
model{
mu ~ normal(0,10);
sigma ~ normal(0,5);
r ~ normal(mu,sigma);
}
"
stan_data <- list(
N = length(returns),
r = returns
)
fit <- stan(
model_code = stan_model_code,
data = stan_data,
iter = 2000,
chains = 4
)
print(fit)
traceplot(fit)
posterior <- extract(fit)
sim_returns <- rnorm(
1000,
mean = mean(posterior$mu),
sd = mean(posterior$sigma)
)
hist(returns,
breaks=40,
probability=TRUE,
col="gray",
main="Posterior Predictive Check")
hist(sim_returns,
breaks=40,
add=TRUE,
col=rgb(1,0,0,0.3))
